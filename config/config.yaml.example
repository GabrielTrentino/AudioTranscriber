# Copie para config.yaml na raiz do projeto (opcional).
# Variáveis de ambiente WHISPER_* têm prioridade quando definidas.

device: cpu
pause_gap_seconds: 1.5
output_format: line
default_language: pt
default_model: base
default_compute_type: int8
default_memory_profile: balanced
default_quality_preset: equilibrada

# cpu_threads: 0
# num_workers: 1
# chunk_length: 30
# beam_size: 5

# API (audiotranscriber-api)
# api_host: 127.0.0.1
# api_port: 8000
# api_key: change-me
# cors_origins: http://localhost:3000
# rate_limit_requests: 60
# rate_limit_window_seconds: 60

# Diarização (pyannote / Hugging Face) — ver README
# diarization_backend: pyannote
# HF_TOKEN definido no ambiente (não coloque o token neste arquivo)
# diarization_num_speakers: 2
# diarization_min_speakers: 1
# diarization_max_speakers: 4
